# Environment Variables — InfluxDB 3 Custom Image
# =============================================================================
# Copy file ini menjadi .env lalu isi nilainya:
#   cp .env.example .env
#
# JANGAN commit file .env ke Git! File ini sudah ada di .gitignore.
# =============================================================================

# ── InfluxDB ─────────────────────────────────────────────────────────────────

# Port yang di-expose ke host (default: 8086)
INFLUXDB_PORT=8086

# Node identifier prefix (muncul di log, berguna untuk multi-instance)
NODE_ID=local

# Static admin token — HARUS sama persis dengan nilai di config/admin-token.json
# Digunakan oleh influxdb-init sidecar untuk memanggil influxdb3 CLI
INFLUX_TOKEN=apiv3_Z71qWXoxUl-xXBxD4RHHrn2GNn9dH_l0bel5G7Vqmm6Z-JupQskVsMeGKPeehc_sQpTJwGTgtpFZRF6E3hNrqA
